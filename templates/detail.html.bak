{% extends "base.html" %}
{% block title %}{{ item.title if item else kisskh_drama.title if kisskh_drama else 'Detail' }} - KdramaShows{% endblock %}
{% block content %}

{% if embed %}
<section style="background:#000;min-height:100vh;">
{% else %}
<section class="py-5 mt-5">
{% endif %}
    <div class="container">
        {% if not embed %}
        <div class="row mb-4" id="detailHeader">
            <div class="col-md-3">
                <div id="posterContainer">
                    {% if kisskh_drama and kisskh_drama.thumbnail %}
                    <img src="{{ kisskh_drama.thumbnail }}" class="img-fluid rounded shadow" alt="{{ kisskh_drama.title }}" loading="lazy">
                    {% elif item %}
                    <div class="placeholder-poster d-flex align-items-center justify-content-center" style="background:{{ item.color }}20;position:relative;">
                        <span style="font-size:4rem;font-weight:700;color:{{ item.color }};">{{ (item.title or '?')[0] | upper }}</span>
                        <span class="play-icon" style="position:absolute;bottom:15px;right:15px;"><i class="bi bi-play-circle-fill" style="font-size:2.5rem;color:{{ item.color }};opacity:0.6;"></i></span>
                    </div>
                    {% else %}
                    <div class="placeholder-poster d-flex align-items-center justify-content-center">
                        <i class="bi bi-film fs-1 text-muted"></i>
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="col-md-9">
                <h2 class="fw-bold" id="detailTitle">{{ item.title if item else kisskh_drama.title if kisskh_drama else 'Now Playing' }}</h2>
                <div class="d-flex flex-wrap gap-2 mb-3" id="detailMeta">
                    {% if item and item.year %}
                    <span class="badge bg-secondary">{{ item.year }}</span>
                    {% endif %}
                    {% if item and item.quality %}
                    <span class="badge bg-success">{{ item.quality }}</span>
                    {% endif %}
                    {% if kisskh_drama %}
                    {% if kisskh_drama.release_date %}
                    <span class="badge bg-secondary">{{ kisskh_drama.release_date[:4] }}</span>
                    {% endif %}
                    {% if kisskh_drama.country %}
                    <span class="badge bg-light text-dark">{{ kisskh_drama.country }}</span>
                    {% endif %}
                    {% if kisskh_drama.status %}
                    <span class="badge bg-info text-dark">{{ kisskh_drama.status }}</span>
                    {% endif %}
                    {% endif %}
                    <span class="badge bg-{{ 'info text-dark' if media_type == 'tv' else 'primary' }}">{{ 'TV Show' if media_type == 'tv' else 'Movie' }}</span>
                </div>
                <div id="detailExtra" class="text-muted">
                    {% if kisskh_drama and kisskh_drama.episodes_count %}
                    <small>{{ kisskh_drama.episodes_count }} episode(s)</small>
                    {% endif %}
                </div>
                <div id="detailGenres" class="mb-2"></div>
                <p id="detailSummary" class="text-muted">{{ kisskh_drama.description if kisskh_drama and kisskh_drama.description else '' }}</p>
            </div>
        </div>
        {% endif %}

        {% if kisskh_drama and kisskh_drama.episodes and kisskh_drama.episodes[0] %}
        {% set first_ep = kisskh_drama.episodes[0] %}
        <!-- KissKh HLS Player -->
        <div class="player-wrapper mb-4" id="playerWrap">
            <div class="player-container" id="playerContainer">
                <video id="kisskhVideo"
                       data-kisskh-id="{{ kisskh_id }}"
                       data-episode-id="{{ first_ep.id }}"
                       data-title="{{ (kisskh_drama.title or '') }}"
                       class="w-100 rounded shadow"
                       autoplay
                       playsinline
                       tabindex="0"
                       poster=""></video>
                <div class="player-overlay" id="playerOverlay">
                    <div class="player-loader">
                        <div class="player-spinner"></div>
                        <div class="player-loader-text">
                            <span class="player-loader-title">Preparing Stream</span>
                            <span class="player-loader-sub" id="playerLoaderSub">Contacting server...</span>
                        </div>
                    </div>
                </div>
                <div class="custom-controls" id="customControls">
                    <div class="controls-progress">
                        <input type="range" class="controls-seek" id="seekBar" min="0" max="100" value="0" step="0.1">
                        <div class="controls-buffer" id="bufferBar"></div>
                    </div>
                    <div class="controls-main">
                        <div class="controls-left">
                            <button class="ctrl-btn" id="playBtn" title="Play/Pause"><i class="bi bi-play-fill"></i></button>
                            <span class="controls-time" id="timeDisplay">0:00 / 0:00</span>
                        </div>
                        <div class="controls-center">
                            <button class="ctrl-btn" id="rewindBtn" title="-10s"><i class="bi bi-skip-backward-fill"></i></button>
                            <button class="ctrl-btn" id="forwardBtn" title="+10s"><i class="bi bi-skip-forward-fill"></i></button>
                        </div>
                        <div class="controls-right">
                            <div class="volume-wrap">
                                <button class="ctrl-btn" id="volumeBtn" title="Mute"><i class="bi bi-volume-up-fill"></i></button>
                                <input type="range" class="controls-volume" id="volumeBar" min="0" max="1" step="0.05" value="1">
                            </div>
                            <span class="controls-quality" id="qualityDisplay">HD</span>
                            <button class="ctrl-btn" id="fullscreenBtn" title="Fullscreen"><i class="bi bi-fullscreen"></i></button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="player-info-bar">
                <div class="player-info-left">
                    <span class="badge bg-danger">KissKh HD</span>
                    <span class="player-episode-badge">
                        <i class="bi bi-play-circle me-1"></i>Episode <span id="currentEpisodeLabel">1</span>
                    </span>
                </div>
                <div class="player-info-right">
                    <span id="playerStatus" class="player-status">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span> Loading stream...
                    </span>
                    <span id="subtitleStatus" class="player-subtitle-status"></span>
                </div>
            </div>
        </div>
        {% elif sources and sources[0] and sources[0].ok %}
        <!-- Embed Player (regular sources) -->
        <div class="ratio ratio-16x9 mb-4" id="playerWrap">
            <iframe id="mainEmbed" data-imdb="{{ imdb_id }}" data-type="{{ media_type }}" src="{{ sources[0].url }}" allowfullscreen referrerpolicy="origin" loading="lazy"></iframe>
        </div>

        <!-- Source Selector -->
        <div class="d-flex align-items-center justify-content-center gap-2 mb-2 flex-wrap">
            <span class="text-muted small">Server:</span>
            {% for s in sources %}
            <button class="btn btn-sm source-btn {% if loop.first %}btn-kdrama{% else %}btn-outline-secondary{% endif %}" data-base="{{ s.base }}" data-fmt="{{ s.fmt }}">
                {{ s.name }}
            </button>
            {% endfor %}
        </div>

        <!-- Proxy Toggle -->
        <div class="text-center mb-3">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="proxyMode" id="proxyOff" value="off" checked>
                <label class="form-check-label small" for="proxyOff">Direct</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="proxyMode" id="proxyOn" value="on">
                <label class="form-check-label small" for="proxyOn">Proxy (bypass blocks)</label>
            </div>
            <span class="text-muted ms-2 small">Try Proxy if direct doesn't load</span>
        </div>
        {% else %}
        <!-- No video source available -->
        <div class="alert alert-warning text-center">
            <i class="bi bi-exclamation-triangle me-2"></i>
            No video source available for this content.
        </div>
        {% endif %}

        {% if media_type == 'tv' %}
        {% if kisskh_drama and kisskh_drama.episodes %}
        <!-- Episode selector for KissKh -->
        <div class="row mb-4">
            <div class="col-md-6">
                <label class="form-label fw-bold">Episode</label>
                <select id="kisskhEpisodeSelect" class="form-select">
                    {% for ep in kisskh_drama.episodes | sort(attribute='number') %}
                    <option value="{{ ep.id }}" data-number="{{ ep.number }}" {% if loop.first %}selected{% endif %}>
                        Episode {{ ep.number }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-6 d-flex align-items-end">
                <button id="loadKisskhEpisodeBtn" class="btn btn-kdrama w-100">
                    <i class="bi bi-play-fill me-1"></i>Load Episode
                </button>
            </div>
        </div>
        {% else %}
        <!-- Fallback: manual season/episode selector for embed sources -->
        <div class="row mb-4">
            <div class="col-md-4">
                <label class="form-label fw-bold">Season</label>
                <select id="seasonSelect" class="form-select">
                    {% for i in range(1, 13) %}
                    <option value="{{ i }}" {% if i == 1 %}selected{% endif %}>Season {{ i }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Episode</label>
                <select id="episodeSelect" class="form-select">
                    {% for i in range(1, 51) %}
                    <option value="{{ i }}" {% if i == 1 %}selected{% endif %}>Episode {{ i }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button id="loadEpisodeBtn" class="btn btn-kdrama w-100">Load Episode</button>
            </div>
        </div>
        {% endif %}
        {% endif %}

        {% if not embed %}
        <div class="text-center">
            <a href="{{ url_for('browse', type=media_type) }}" class="btn btn-outline-light">&larr; Back to Browse</a>
        </div>
        {% endif %}
    </div>
</section>

{% if kisskh_drama and kisskh_drama.episodes %}
<script>
var kisskhEpisodes = {{ kisskh_drama.episodes | sort(attribute='number') | tojson | safe }};
var kisskhId = {{ kisskh_id | tojson | safe }};
</script>
{% endif %}
{% endblock %}